{
  "name": "aix-format",
  "version": "1.3.0",
  "description": "AIX (Artificial Intelligence eXchange) - Standard file format for AI agents. Sovereign Protocol v1.3 with TypeScript types and Meta Arbiter support.",
  "main": "core/parser.js",
  "types": "types/aix.d.ts",
  "type": "module",
  "bin": {
    "aix-validate": "./bin/aix-validate.js",
    "aix-convert": "./bin/aix-convert.js"
  },
  "scripts": {
    "test": "node --test",
    "test:verbose": "node --test --test-reporter=spec",
    "validate": "node bin/aix-validate.js",
    "validate:examples": "node bin/aix-validate.js examples/persona-agent.aix && node bin/aix-validate.js examples/tool-agent.aix && node bin/aix-validate.js examples/hybrid-agent.aix",
    "generate:types:unified": "json2ts -i schemas/aix.schema.json -o types/aix.d.ts --strictIndexSignatures --unreachableDefinitions",
    "generate:types": "json2ts -i \"schemas/**/*.json\" -o types/",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "studio:dev": "npm run dev --workspace=studio",
    "detective": "node apps/aix-detective/index.js",
    "lint": "echo 'Linting not configured yet'",
    "format": "echo 'Formatting not configured yet'",
    "docs": "echo 'Documentation generation not configured yet'"
  },
  "keywords": [
    "ai",
    "agent",
    "aix",
    "artificial-intelligence",
    "file-format",
    "specification",
    "interoperability",
    "ai-agents",
    "llm",
    "machine-learning",
    "standardization",
    "typescript",
    "meta-arbiter",
    "pi-network",
    "sovereign-protocol"
  ],
  "author": {
    "name": "Mohamed H Abdelaziz",
    "organization": "AMRIKYY AI Solutions",
    "email": "amrikyy@gmail.com",
    "url": "https://amrikyy.ai"
  },
  "contributors": [
    {
      "name": "Mohamed H Abdelaziz",
      "email": "abdela1@students.kennesaw.edu"
    }
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moeabdelaziz007/aix-format.git"
  },
  "bugs": {
    "url": "https://github.com/Moeabdelaziz007/aix-format/issues",
    "email": "amrikyy@gmail.com"
  },
  "homepage": "https://github.com/Moeabdelaziz007/aix-format#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "core/",
    "bin/",
    "schemas/",
    "examples/",
    "docs/",
    "types/",
    "LICENSE.md",
    "COPYRIGHT.md",
    "README.md"
  ],
  "directories": {
    "doc": "docs",
    "test": "tests",
    "example": "examples"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "js-yaml": "^4.1.1",
    "smol-toml": "^1.3.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.4.5"
  }
}
