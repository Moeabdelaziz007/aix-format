{
  "name": "aix-format",
  "version": "0.369.0",
  "description": "AIX (Artificial Intelligence eXchange) - Universal Agent Passport for the agentic payment economy. Sovereign Protocol v0.369.0 with Identity (v0.369.0), Payment Layer (v1.0), HTTP 402, Multi-Chain, and Platform Adapters.",
  "main": "core/parser.js",
  "types": "types/parser.d.ts",
  "type": "module",
  "bin": {
    "aix-validate": "./bin/aix-validate.js",
    "aix-convert": "./bin/aix-convert.js",
    "aix-regulator-export": "./bin/aix-regulator-export.js",
    "aix-plugins": "./bin/aix-plugins.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "node bin/aix-validate.js",
    "validate:examples": "node bin/aix-validate.js examples/persona-agent.aix && node bin/aix-validate.js examples/tool-agent.aix && node bin/aix-validate.js examples/hybrid-agent.aix",
    "validate:env": "vite-node scripts/validate-env.ts",
    "env:check": "vite-node scripts/validate-env.ts",
    "generate:types:unified": "json2ts -i schemas/aix.schema.json -o types/parser.d.ts --strictIndexSignatures --unreachableDefinitions",
    "generate:types": "json2ts -i \"schemas/**/*.json\" -o types/",
    "build": "tsc -p tsconfig.json",
    "studio:dev": "pnpm --filter @aix/studio dev",
    "studio:build": "pnpm --filter @aix/studio build",
    "studio:start": "pnpm --filter @aix/studio start",
    "detective": "node apps/aix-detective/index.js",
    "lint": "echo 'Linting not configured yet'",
    "format": "echo 'Formatting not configured yet'",
    "docs": "echo 'Documentation generation not configured yet'",
    "schema:sync:check": "vite-node scripts/schema-type-sync.ts",
    "schema:sync:fix": "npm run generate:types:unified && npm run schema:sync:check",
    "dead-code:scan": "bash scripts/dead-code-scan.sh",
    "dead-code:report": "cat .generated/dead-code-report.md",
    "health-score": "vite-node scripts/health-score.ts",
    "health-score:report": "cat .generated/health-score.json",
    "health:check": "vite-node scripts/health-score.ts && node scripts/health-trend.js",
    "health:fix": "node scripts/auto-issue-generator.js",
    "health:full": "npm run health:check && npm run health:fix",
    "health:report": "cat .generated/HEALTH_REPORT.md",
    "memory:watch": "vite-node scripts/protect-openmemory.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "aix",
    "artificial-intelligence",
    "file-format",
    "specification",
    "interoperability",
    "ai-agents",
    "llm",
    "machine-learning",
    "standardization",
    "typescript",
    "meta-arbiter",
    "pi-network",
    "sovereign-protocol"
  ],
  "author": {
    "name": "Mohamed H Abdelaziz",
    "organization": "AMRIKYY AI Solutions",
    "email": "amrikyy@gmail.com",
    "url": "https://amrikyy.ai"
  },
  "contributors": [
    {
      "name": "Mohamed H Abdelaziz",
      "email": "abdela1@students.kennesaw.edu"
    }
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moeabdelaziz007/aix-format.git"
  },
  "bugs": {
    "url": "https://github.com/Moeabdelaziz007/aix-format/issues",
    "email": "amrikyy@gmail.com"
  },
  "homepage": "https://github.com/Moeabdelaziz007/aix-format#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "core/",
    "bin/",
    "schemas/",
    "examples/",
    "docs/",
    "types/",
    "LICENSE.md",
    "COPYRIGHT.md",
    "README.md"
  ],
  "directories": {
    "doc": "docs",
    "test": "tests",
    "example": "examples"
  },
  "workspaces": [
    "apps/*",
    "packages/aix-core",
    "packages/aix-rust-core",
    "packages/aix-zkkyc",
    "packages/axiom-schema",
    "packages/mcp-gateway",
    "packages/mcp-server",
    "packages/pi-kyc"
  ],
  "dependencies": {
    "@ai-sdk/google": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^20.0.0",
    "@upstash/redis": "^1.38.0",
    "ai": "^4.0.0",
    "framer-motion": "^11.11.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.474.0",
    "nanoid": "^5.0.0",
    "smol-toml": "^1.3.1",
    "snarkjs": "^0.7.0",
    "stripe": "^17.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ajv": "^8.12.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.4.5",
    "vitest": "^3.0.4"
  },
  "packageManager": "pnpm@9.15.4"
}