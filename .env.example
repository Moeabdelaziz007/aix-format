# AIX Format Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# CORE CONFIGURATION
# ============================================

# AIX Identity Layer
AIX_UID_HASH_SALT=your_random_salt_here_change_in_production

# ============================================
# REDIS / UPSTASH CONFIGURATION
# ============================================

# Upstash Redis (for memory, registry, and swarm coordination)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ============================================
# PI NETWORK CONFIGURATION
# ============================================

# Pi Network API credentials
PI_API_KEY=your_pi_api_key_here
PI_NETWORK_ENV=sandbox  # or 'production'

# ============================================
# AXIOM ID CONFIGURATION
# ============================================

# AxiomID authority for DID verification
AXIOM_AUTHORITY=axiomid.app
AXIOM_API_KEY=your_axiom_api_key_here

# ============================================
# VERCEL / DEPLOYMENT
# ============================================

# Next.js configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=your-app.vercel.app

# ============================================
# SWARM ROUTER (Go Backend)
# ============================================

# Swarm Router HTTP server port
SWARM_ROUTER_PORT=8080

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================

# OpenAI (for embeddings, if using semantic memory)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI (optional)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ============================================
# SECURITY & MONITORING
# ============================================

# JWT secret for authentication
JWT_SECRET=your_jwt_secret_change_in_production

# Sentry (optional, for error tracking)
SENTRY_DSN=your_sentry_dsn_here

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable debug logging
DEBUG=false

# Skip signature verification (NEVER use in production)
SKIP_SIGNATURE_VERIFICATION=false