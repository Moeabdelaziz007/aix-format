# ============================================================
# AIX Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── 🔴 CRITICAL (app won't work without these) ──────────────

# Upstash Redis — storage, sessions, pulse stream
# Get from: https://upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Groq — Voice STT (Whisper large-v3, free tier available)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key

# Google Gemini — Voice Wizard chat (Gemini 2.0 Flash)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza_your_google_key

# xAI Grok — Global Voice Command intelligence
# Get from: https://console.x.ai (REVOKE any exposed keys immediately)
XAI_API_KEY=xai-your_new_grok_key

# ── 🟡 IMPORTANT (features disabled without these) ──────────

# Telegram — Agent channel integration
# Get from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Stripe — Payments
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# WalletConnect — wagmi wallet integration
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── 🟢 OPTIONAL (defaults work for local dev) ────────────────

# App URL (used for internal API calls)
NEXT_PUBLIC_APP_URL=https://axiomid.app

# Studio version (shown in health check)
NEXT_PUBLIC_STUDIO_VERSION=1.3.0

# Log level (debug | info | warn | error)
NEXT_PUBLIC_LOG_LEVEL=info

# ── 🔵 VERCEL CI (set in GitHub Secrets, not .env.local) ─────
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_org_id
# VERCEL_PROJECT_ID=your_project_id
