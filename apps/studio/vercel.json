{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.axiomid.app" }],
      "destination": "https://axiomid.app/$1",
      "permanent": true
    }
  ]
}
