{
  "name": "@aix/core",
  "version": "0.369.0",
  "description": "AIX unified storage adapter - core Redis/Session storage utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/",
    "src/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "redis",
    "storage",
    "aix",
    "session"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "compress": "ts-node scripts/compress.ts",
    "evolve": "ts-node scripts/evolve.ts",
    "compress:measure": "tsc --noEmit && du -sh dist/ 2>/dev/null || echo 'Run build first'"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "@xenova/transformers": "^2.17.2",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "canonical-json": "^0.0.4",
    "framer-motion": "^12.38.0",
    "langfuse": "^3.0.0",
    "ajv": "^8.12.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}