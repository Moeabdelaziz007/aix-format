{
  "name": "@aix/core",
  "version": "0.369.0",
  "description": "AIX unified storage adapter - core Redis/Session storage utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/",
    "src/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "redis",
    "storage",
    "aix",
    "session"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "compress": "ts-node scripts/compress.ts",
    "evolve": "ts-node scripts/evolve.ts",
    "compress:measure": "tsc --noEmit && du -sh dist/ 2>/dev/null || echo 'Run build first'"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "@xenova/transformers": "^2.17.2",
    "langfuse": "^3.30.0",
    "@octokit/rest": "^20.1.1",
    "zod": "^4.4.3",
    "@aix/rust-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^6.0.3"
  }
}
