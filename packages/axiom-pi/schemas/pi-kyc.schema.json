{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axiomid.app/schemas/pi-kyc.schema.json",
  "title": "Pi Network KYC Schema",
  "description": "Schema for Pi Network KYC inputs and results in the AIX ecosystem.",
  "type": "object",
  "definitions": {
    "KycInput": {
      "type": "object",
      "properties": {
        "user": {
          "type": "object",
          "properties": {
            "uid": {
              "type": "string",
              "minLength": 10,
              "description": "The Pi Network unique user identifier."
            }
          },
          "required": ["uid"]
        },
        "accessToken": {
          "type": "string",
          "minLength": 1,
          "description": "The Pi Network access token obtained from the SDK."
        },
        "signature": {
          "type": "string",
          "description": "Optional Ed25519 signature for blockchain anchoring."
        },
        "publicKey": {
          "type": "string",
          "description": "Optional public key for VLA device identification."
        }
      },
      "required": ["user", "accessToken"]
    },
    "KycProof": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "Version of the KYC proof format."
        },
        "provider": {
          "type": "string",
          "enum": ["pi_network"],
          "description": "The KYC service provider."
        },
        "uid_hash": {
          "type": "string",
          "description": "SHA-256 hash of the Pi UID."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of verification."
        },
        "blockchain_anchor": {
          "type": "string",
          "description": "Anchor hash on the blockchain."
        },
        "vla_device_id": {
          "type": "string",
          "description": "Identifier for the VLA device."
        }
      },
      "required": ["version", "provider", "uid_hash", "timestamp"]
    },
    "IdentityLayer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:axiom:pi:[a-zA-Z0-9._\\-]+$",
          "description": "The Decentralized Identifier (DID) for the user."
        },
        "authority": {
          "type": "string",
          "description": "The issuing authority (e.g., axiomid.app)."
        },
        "issuedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of issuance."
        }
      },
      "required": ["id", "authority", "issuedAt"]
    },
    "KycResult": {
      "type": "object",
      "properties": {
        "identity_layer": { "$ref": "#/definitions/IdentityLayer" },
        "kyc_proof": { "$ref": "#/definitions/KycProof" }
      },
      "required": ["identity_layer", "kyc_proof"]
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/KycInput" },
    { "$ref": "#/definitions/KycResult" }
  ]
}
