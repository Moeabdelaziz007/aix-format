{
  "name": "@aix/rust-core",
  "version": "0.1.0",
  "description": "High-performance Rust core for AIX agent framework",
  "main": "index.node",
  "types": "index.d.ts",
  "scripts": {
    "build": "cargo build --release && neon build --release",
    "build:debug": "cargo build && neon build",
    "test": "cargo test && npm run test:ts",
    "test:ts": "vitest run",
    "bench": "cargo bench",
    "clean": "cargo clean && rm -rf target/ index.node"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "index.node",
    "index.d.ts",
    "src/bridge.ts"
  ],
  "keywords": [
    "rust",
    "neon",
    "ffi",
    "performance",
    "agent",
    "aix"
  ],
  "author": "AIX Team",
  "license": "MIT"
}