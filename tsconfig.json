{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationDir": "./types",
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@aix-core/*": [
        "packages/aix-core/src/*"
      ],
      "@aix-agency/*": [
        "packages/aix-agency/pkg/*"
      ],
      "@aix-zkkyc/*": [
        "packages/aix-zkkyc/src/*"
      ],
      "@mcp-gateway/*": [
        "packages/mcp-gateway/src/*"
      ],
      "@studio/*": [
        "apps/studio/src/*"
      ],
      "@types/aix": [
        "types/aix.d.ts"
      ]
    }
  },
  "include": [
    "core/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps",
    "tests"
  ]
}