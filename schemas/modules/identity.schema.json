{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://amrikyy.ai/schemas/modules/identity.schema.json",
  "title": "AIX Identity Module (Provider Agnostic)",
  "type": "object",
  "required": [
    "id",
    "provider",
    "issuedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique decentralized identifier (DID) for the agent."
    },
    "provider": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["pi_network", "world_id", "ens", "custom"],
          "description": "The identity provider type."
        },
        "name": {
          "type": "string",
          "description": "Friendly name of the provider."
        },
        "authority": {
          "type": "string",
          "description": "The root authority domain or address (e.g., axiomid.app)."
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unverified", "verified", "rejected", "pending"],
          "default": "unverified"
        },
        "trust_level": {
          "type": "integer",
          "description": "Normalized trust score or tier (0-3).",
          "minimum": 0,
          "maximum": 3,
          "default": 0
        },
        "provider_specific_tier": {
          "type": "string",
          "description": "Original tier/status from the provider (e.g., Pi KYC Tier 2)."
        }
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "publicKey": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "type": "string" },
        "value": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
