{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://amrikyy.ai/schemas/modules/economics.schema.json",
  "title": "AIX Economics Module (Multi-Chain Settlement)",
  "type": "object",
  "properties": {
    "settlement": {
      "type": "object",
      "description": "Provider-agnostic settlement layer configuration.",
      "required": ["layer", "network"],
      "properties": {
        "layer": {
          "type": "string",
          "enum": ["pi_network", "ethereum", "solana", "stripe", "custom"],
          "description": "The settlement layer/provider."
        },
        "network": {
          "type": "string",
          "description": "Target network (e.g., mainnet, testnet)."
        },
        "contract_address": {
          "type": "string",
          "description": "On-chain contract address if applicable."
        },
        "escrow_enabled": {
          "type": "boolean",
          "default": false
        },
        "currency": {
          "type": "string",
          "default": "PI"
        }
      }
    },
    "pricing": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["pay_per_call", "subscription", "freemium", "tiered"],
          "default": "pay_per_call"
        },
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "cost"],
            "properties": {
              "name": { "type": "string" },
              "cost": {
                "type": "object",
                "required": ["amount", "currency"],
                "properties": {
                  "amount": { "type": "number", "minimum": 0 },
                  "currency": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
